{
  "name": "pico-web",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev":       "turbo dev",
    "build":     "turbo build",
    "lint":      "turbo lint",
    "typecheck": "turbo typecheck",
    "format":    "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "test":      "turbo test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver", "@swc/core"]
  },
  "devDependencies": {
    "turbo":       "^2.0.0",
    "typescript":  "^5.4.0",
    "prettier":    "^3.2.0",
    "@types/node": "^20.0.0"
  }
}
